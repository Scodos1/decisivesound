EMAIL_HOST_USER=your-gmail-address@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-app-password
DEFAULT_FROM_EMAIL=your-gmail-address@gmail.com

# --- PostgreSQL ---
# Option A: individual settings (used if DATABASE_URL below is not set)
DB_NAME=decisivesounds
DB_USER=postgres
DB_PASSWORD=your-postgres-password
DB_HOST=localhost
DB_PORT=5432

# Option B: a single connection string, common with managed Postgres hosts
# (Railway, Render, Supabase, ElephantSQL, Heroku...). If set, this
# overrides all four DB_* settings above.
# DATABASE_URL=postgres://user:password@host:5432/dbname

# --- Paystack (booking/paystack.py) ---
# Use your test secret key while developing, live key only in production.
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Cloudinary (media storage - Gallery photos/videos, documents) ---
# Only needed in production. Leave unset locally - uploads just go to the
# local media/ folder instead. Get this value from your Cloudinary
# dashboard (cloudinary.com > Dashboard > "API Environment variable",
# copy the whole CLOUDINARY_URL=... line as-is).
# CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
